APP_NAME=SIIM
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_TIMEZONE=America/Lima

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=siim
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=siim-local
REVERB_APP_KEY=
REVERB_APP_SECRET=

MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

LLM_PRIMARY=nvidia_glm
LLM_FALLBACK=
LLM_DAILY_BUDGET_USD=5.00

# NVIDIA NIM (GLM 5.1) — Asistente virtual + análisis NLP
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=z-ai/glm-5.1
NVIDIA_VERIFY_SSL=true

# Otros providers (opcionales)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
