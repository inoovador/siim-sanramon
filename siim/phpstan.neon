includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    level: max
    paths:
        - app
        - src
        - tests
        - database
    excludePaths:
        - vendor
        - storage
        - bootstrap/cache
        - tests/Arch/*
    treatPhpDocTypesAsCertain: false
    checkMissingIterableValueType: true
    checkGenericClassInNonGenericObjectType: true
